digraph code_review {
  goal = "Review code quality and decide if it needs improvement"

  node [shape=box]

  start   [shape=circle, type=start]
  review  [type=codergen, label="Review code",
           prompt="Review this Python function and rate it 1-10 for code quality. Reply with only a JSON object: {\"score\": <number>, \"verdict\": \"pass\" if score >= 7 else \"fail\", \"feedback\": \"<one sentence>\"}\n\ndef get_users(db, admin=False):\n    query = \"SELECT * FROM users\"\n    if admin:\n        query += \" WHERE role = 'admin'\"\n    result = db.execute(query)\n    users = []\n    for row in result:\n        users.append({\"id\": row[0], \"name\": row[1], \"email\": row[2]})\n    return users"]
  improve [type=codergen, label="Suggest improvements",
           prompt="Suggest 3 specific improvements for this Python function as a bulleted list:\n\ndef get_users(db, admin=False):\n    query = \"SELECT * FROM users\"\n    if admin:\n        query += \" WHERE role = 'admin'\"\n    result = db.execute(query)\n    users = []\n    for row in result:\n        users.append({\"id\": row[0], \"name\": row[1], \"email\": row[2]})\n    return users"]
  approve [type=codergen, label="Write approval note",
           prompt="Write a one-sentence approval note for code that passed review with a score of 7 or above."]
  exit    [shape=Msquare, type=exit]

  start   -> review
  review  -> improve [label="needs work", condition="context.review.verdict=fail"]
  review  -> approve [label="looks good",  condition="context.review.verdict=pass"]
  improve -> exit
  approve -> exit
}
